# Solana auth server — copy to .env and adjust. Never commit real secrets.

# HTTP port for Node (default 3001 if unset in code paths that read PORT).
PORT=3001

# Resend (https://resend.com) — required to send real emails; if empty, emails are stub-logged.
RESEND_API_KEY=re_xxxxxxxx

# Verified sender address in Resend (must match your domain setup).
FROM_EMAIL=noreply@example.com

# Admin inbox for signup notifications and alerts.
ADMIN_EMAIL=admin@example.com

# Public URL of the deployed SPA (emails, links). Example: https://app.example.com
APP_URL=http://localhost:3001

# Browser origin allowed for CORS (exact match). Example: https://app.example.com — omit for same-origin only in some setups.
CORS_ORIGIN=http://localhost:5173

# HMAC secret for session tokens — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=

# Anthropic API key for /ai routes (optional; features disabled if unset).
ANTHROPIC_API_KEY=

# SQLite and file storage root (optional; default ./data next to server.js).
DATA_DIR=

# Cloudinary — optional; receipts stored on disk under DATA_DIR if unset.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder name in Cloudinary for receipt assets.
CLOUDINARY_RECEIPTS_FOLDER=solana-receipts

# Set to "true" only in controlled environments to allow seed/bootstrap endpoints.
ALLOW_SEED=false

# Shared secret for bootstrap/seed HTTP calls when ALLOW_SEED is true.
BOOTSTRAP_SECRET=
